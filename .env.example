# Navigation Engine
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8001
DATA_ROOT=../../data
DEMO_MODE=true

# Frontend
NEXT_PUBLIC_ENGINE_BASE_URL=http://localhost:8001

# VNPT feature toggles
# false = offline mock adapter, true = real VNPT API
USE_STT_PREPROCESSING=false
USE_VNPT_SMARTVOICE_STT=false
USE_VNPT_SMARTVOICE_TTS=false
USE_VNPT_SMARTBOT=false
USE_VNPT_SMARTREADER=false
# Backward-compatible umbrella flag. Prefer the per-feature STT/TTS flags above.
USE_VNPT_SMARTVOICE=false

# SmartVoice STT - Speech to Text
# Calls:
#   POST {VNPT_SMARTVOICE_STT_BASE_URL}{VNPT_SMARTVOICE_STT_PATH}
# with multipart field "audioFile" and "clientSession".
# Use the synchronous gRPC endpoint for the current repo:
#   /stt-service/v1/grpc/standard
VNPT_SMARTVOICE_STT_BASE_URL=
VNPT_SMARTVOICE_STT_PATH=/stt-service/v1/grpc/standard
VNPT_SMARTVOICE_STT_MODEL=online
VNPT_SMARTVOICE_STT_MAX_ALTERNATIVES=1
VNPT_SMARTVOICE_STT_AUDIO_CHANNEL_COUNT=1
VNPT_SMARTVOICE_STT_ENABLE_WORD_TIME_OFFSETS=false
VNPT_SMARTVOICE_STT_ENABLE_AUTOMATIC_PUNCTUATION=false
VNPT_SMARTVOICE_STT_ENABLE_SEPARATE_RECOGNITION_PER_CHANNEL=false
VNPT_SMARTVOICE_STT_VERBATIM_TRANSCRIPTS=false
VNPT_SMARTVOICE_STT_INVERT_TEXT=1
VNPT_SMARTVOICE_STT_CAP_PUNCT_RECOVERY=1
VNPT_SMARTVOICE_STT_CONVERT_FORMAT=
VNPT_SMARTVOICE_STT_TOKEN_ID=
VNPT_SMARTVOICE_STT_TOKEN_KEY=
VNPT_SMARTVOICE_STT_ACCESS_TOKEN=

# SmartVoice TTS - Text to Speech
# Calls VNPT /tts-service/v2/standard, then downloads object.playlist[0].audio_link.
VNPT_SMARTVOICE_TTS_BASE_URL=
VNPT_SMARTVOICE_TTS_PATH=/tts-service/v2/standard
VNPT_SMARTVOICE_TTS_TOKEN_ID=
VNPT_SMARTVOICE_TTS_TOKEN_KEY=
VNPT_SMARTVOICE_TTS_ACCESS_TOKEN=
VNPT_SMARTVOICE_TTS_MODEL=news
VNPT_SMARTVOICE_TTS_REGION=female_north
VNPT_SMARTVOICE_TTS_AUDIO_FORMAT=wav
VNPT_SMARTVOICE_TTS_SAMPLE_RATE=22050
VNPT_SMARTVOICE_TTS_USE_ABBR_CONVERTER=true
VNPT_SMARTVOICE_TTS_AUTO_SILENCE=false
VNPT_SMARTVOICE_TTS_CLEAR_CACHED=false
VNPT_SMARTVOICE_TTS_DOMAIN=general
VNPT_SMARTVOICE_TTS_SPEED=1.0
VNPT_SMARTVOICE_TTS_PROSODY=0.0

# Legacy SmartVoice fallback shared by STT/TTS. Prefer the feature-specific vars above.
VNPT_SMARTVOICE_BASE_URL=
VNPT_SMARTVOICE_TOKEN_ID=
VNPT_SMARTVOICE_TOKEN_KEY=
VNPT_SMARTVOICE_ACCESS_TOKEN=

# SmartBot - chatbot / voicebot conversation
# If you provide the host root, the adapter appends /v1/conversation.
# You may also provide the full endpoint:
#   https://assistant-stream.vnpt.vn/v1/conversation
VNPT_SMARTBOT_BASE_URL=https://assistant-stream.vnpt.vn
VNPT_SMARTBOT_URL=https://assistant-stream.vnpt.vn/v1/conversation
VNPT_SMARTBOT_TOKEN_ID=
VNPT_SMARTBOT_TOKEN_KEY=
VNPT_SMARTBOT_ACCESS_TOKEN=
VNPT_SMARTBOT_BOT_ID=
VNPT_SMARTBOT_INPUT_CHANNEL=livechat
VNPT_SMARTBOT_USE_LOCAL_PROMPTS=false


# SmartReader - OCR
# Table OCR endpoint for paper instruction forms.
VNPT_SMARTREADER_BASE_URL=
VNPT_SMARTREADER_OCR_PATH=/rpa-service/aidigdoc/v1/ocr/scan-table
VNPT_SMARTREADER_TOKEN_ID=
VNPT_SMARTREADER_TOKEN_KEY=
VNPT_SMARTREADER_ACCESS_TOKEN=